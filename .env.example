# Entorno
NODE_ENV=production

# Puerto de la UI (también configurable desde la UI, requiere reinicio)
PORT=3847

# Path al directorio de datos (por defecto: ./data)
DATA_DIR=./data

# Path a logs (por defecto: ./logs)
LOG_DIR=./logs

# Nivel de log (error, warn, info, debug)
LOG_LEVEL=info

# Retención de logs en días
LOG_RETENTION_DAYS=30
